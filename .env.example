# Claude API key — required for Dutch → English description translation
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: residential proxy URL for running the scraper from a server
# Leave blank to use your direct IP (recommended for home/office use)
# Format: http://user:pass@host:port
PROXY_URL=

# Scrape settings (override defaults from config/settings.py)
# REQUEST_DELAY=2.0
# MAX_RETRIES=3
