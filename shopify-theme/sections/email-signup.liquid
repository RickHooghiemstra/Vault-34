{%- comment -%}
  EMAIL SIGNUP SECTION
  Full-width CTA with Klaviyo/Shopify newsletter form.
{%- endcomment -%}

<section class="section">
  <div class="container">
    <div class="email-signup reveal">
      <div style="position:relative;z-index:1">
        {%- if section.settings.label != blank -%}
          <p class="label" style="margin-bottom:var(--space-4)">{{ section.settings.label }}</p>
        {%- endif -%}

        <h2 class="h2" style="margin-bottom:var(--space-4)">{{ section.settings.title }}</h2>

        {%- if section.settings.subtitle != blank -%}
          <p style="font-size:var(--text-lg);color:var(--text-muted);max-width:480px;margin:0 auto var(--space-8)">
            {{ section.settings.subtitle }}
          </p>
        {%- endif -%}

        <!-- Incentive badges -->
        {%- if section.settings.show_incentives -%}
          <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:var(--space-3);margin-bottom:var(--space-6)">
            <span class="badge badge-purple">🏍️ Exhaust launch alerts</span>
            <span class="badge badge-purple">🔧 Setup tips & guides</span>
            <span class="badge badge-purple">💰 Exclusive discounts</span>
          </div>
        {%- endif -%}

        <!-- Form -->
        {%- form 'customer', id: 'newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="email-signup__form">
            <input
              type="email"
              name="contact[email]"
              class="email-signup__input"
              placeholder="{{ section.settings.placeholder | default: 'your@email.com' }}"
              required
              autocomplete="email"
              aria-label="Email address"
            >
            <button type="submit" class="btn btn-primary btn-lg" style="flex-shrink:0">
              {{ section.settings.cta | default: 'Get Updates' }}
              <svg width="14" height="14" fill="none" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>

          {%- if form.posted_successfully? -%}
            <p style="color:var(--color-success);font-size:var(--text-sm);margin-top:var(--space-4)">
              ✓ You're in! We'll send you the good stuff.
            </p>
          {%- endif -%}

          {%- if form.errors -%}
            <p style="color:var(--color-error);font-size:var(--text-sm);margin-top:var(--space-4)">
              {{ form.errors | default_errors }}
            </p>
          {%- endif -%}
        {%- endform -%}

        <p style="font-size:var(--text-xs);color:var(--text-subtle);margin-top:var(--space-4)">
          {{ section.settings.disclaimer | default: 'No spam. Unsubscribe any time. We hate clutter too.' }}
        </p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Email Signup",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow label",
      "default": "Join the Community"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Get Early Access to New Exhausts"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Be first to know about new launches, exclusive rider deals, and setup guides."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "cta",
      "label": "Button label",
      "default": "Get Updates"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer text",
      "default": "No spam. Unsubscribe any time."
    },
    {
      "type": "checkbox",
      "id": "show_incentives",
      "label": "Show incentive badges",
      "default": true
    }
  ],
  "presets": [{ "name": "Email Signup" }]
}
{% endschema %}
