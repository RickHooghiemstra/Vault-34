{%- comment -%}
  FITMENT FINDER SECTION
  Cascading dropdowns: Make → Model → Year → Search.
  Data is built from real product tags: MAKE_*, MODEL_*, YEAR_*
{%- endcomment -%}

{%- if section.settings.bg_style == 'dark' -%}
  {%- assign section_bg = 'var(--bg-base)' -%}
{%- else -%}
  {%- assign section_bg = 'var(--bg-elevated)' -%}
{%- endif -%}

<section id="fitment" class="section-sm" style="background:{{ section_bg }}">
  <div class="container">
    <div class="fitment-bar reveal" data-fitment-bar>

      <!-- Header row -->
      <div class="fitment-bar__label">
        <div class="fitment-bar__label-icon" aria-hidden="true">
          <svg width="18" height="18" fill="none">
            <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M9 5v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <h2 class="h4" style="margin-bottom:var(--space-1)">
            {{ section.settings.title | default: 'Find Parts for Your Bike' }}
          </h2>
          <p style="font-size:var(--text-sm);color:var(--text-subtle)">
            {{ section.settings.subtitle | default: 'Select your make, model and year to see exactly what fits.' }}
          </p>
        </div>
      </div>

      <!-- Selectors -->
      <div class="fitment-bar__selects">

        <!-- Make -->
        <div class="fitment-select-group">
          <label class="form-label" for="fitment-make">Make</label>
          <select
            id="fitment-make"
            class="form-select"
            data-fitment-make
            aria-label="Select motorcycle make"
          >
            <option value="">Select Make</option>
          </select>
        </div>

        <!-- Model (disabled until Make selected) -->
        <div class="fitment-select-group">
          <label class="form-label" for="fitment-model">Model</label>
          <select
            id="fitment-model"
            class="form-select"
            data-fitment-model
            disabled
            aria-label="Select motorcycle model"
          >
            <option value="">Select Model</option>
          </select>
        </div>

        <!-- Year (disabled until Model selected) -->
        <div class="fitment-select-group">
          <label class="form-label" for="fitment-year">Year</label>
          <select
            id="fitment-year"
            class="form-select"
            data-fitment-year
            disabled
            aria-label="Select motorcycle year"
          >
            <option value="">Select Year</option>
          </select>
        </div>

        <!-- Submit -->
        <div class="fitment-select-group" style="align-self:flex-end">
          <button
            class="btn btn-primary btn-full"
            data-fitment-submit
            aria-label="Search compatible products"
            style="height:48px"
          >
            <svg width="16" height="16" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Find Parts
          </button>
        </div>

      </div><!-- /selects -->

      <!-- Hint -->
      <p class="fitment-hint">
        {{ section.settings.hint | default: 'Compatible with 500+ bike models — updated weekly' }}
      </p>

      <!-- Recent searches (populated by JS from localStorage) -->
      <div id="fitment-recent" style="display:none;margin-top:var(--space-4);padding-top:var(--space-4);border-top:1px solid var(--border-subtle)">
        <p style="font-size:var(--text-xs);color:var(--text-subtle);letter-spacing:var(--tracking-wider);text-transform:uppercase;margin-bottom:var(--space-3)">Your Recent Bikes</p>
        <div id="fitment-recent-list" style="display:flex;flex-wrap:wrap;gap:var(--space-2)"></div>
      </div>

    </div><!-- /fitment-bar -->
  </div>
</section>

<script>
(function() {
  // Real fitment data built from product tags (MAKE_*, MODEL_*, YEAR_*)
  // Keys match tag values exactly so URLs resolve correctly:
  // /collections/all/MAKE_{make}+MODEL_{model}+YEAR_{year}
  window.vault34FitmentData = window.vault34FitmentData || {
    "Yamaha": {
      "MT_07":    [2021,2022,2023,2024],
      "MT_09":    [2021,2022,2023],
      "MT_10":    [2022],
      "MT_03":    [2022],
      "XSR_125":  [2021,2022,2023,2024,2025],
      "XSR_700":  [2021,2022,2023,2024],
      "XSR_900":  [2022,2023,2024],
      "R3":       [2022],
      "YZF_R7":   [2021,2022],
      "Tracer_9": [2021,2022,2023,2024],
      "Tracer_7": [2020,2021,2022,2023],
      "TMAX_560": [2020,2021,2022,2023,2024],
      "XMAX_125": [2021,2022,2023,2024]
    },
    "Honda": {
      "CB_125":   [2021,2022,2023,2024],
      "NC_750":   [2021,2022,2023],
      "Forza_750":[2021,2022,2023],
      "CMX_1100": [2021,2022,2023,2024],
      "CRF_300":  [2021,2022],
      "CRF_450":  [2021],
      "CRF_250":  [2022,2023],
      "MSX_125":  [2021,2022],
      "SH_350":   [2021,2022,2023]
    },
    "BMW": {
      "S1000R":       [2021,2022,2023],
      "R_1300":       [2024,2025,2026],
      "F_900":        [2020,2021,2022,2023,2024],
      "G310R_G310GS": [2017,2018,2019,2020,2021,2022,2023]
    },
    "Kawasaki": {
      "Ninja_ZX_10R": [2021,2022],
      "ZX_10_R":      [2016,2017,2018,2019,2020,2021,2022],
      "Z900":         [2025]
    },
    "Ducati": {
      "Panigale_V2":     [2020,2021,2022],
      "HYPERMOTARD_950": [2021,2022,2023],
      "SCRAMBLER_1100":  [2021],
      "Scrambler_Urban": [2021,2022]
    },
    "Aprilia": {
      "RSV4":      [2021,2022,2023,2024],
      "Tuono_660": [2021,2022,2023],
      "TUAREG_660":[2022],
      "RX":        [2021,2022]
    },
    "KTM": {
      "125_Duke":      [2021,2022],
      "Duke_390":      [2021,2022],
      "390_Adventure": [2020,2021,2022],
      "1290_Superduke":[2020,2021,2022,2023]
    },
    "Triumph": {
      "Trident_660":  [2021,2022,2023,2024],
      "SPEED_TRIPLE": [2021,2022,2023],
      "Tiger_900":    [2020,2021,2022],
      "TIGER_660":    [2022,2023,2024,2025]
    },
    "Suzuki": {
      "SV650":     [2016,2017,2018,2019,2020,2021,2022,2023,2024],
      "GSX_R_600": [2004,2005]
    },
    "Harley_Davidson": {
      "Pan_America": [2021,2022,2023,2024]
    },
    "Moto_Guzzi": {
      "V85_TT": [2019,2020,2021,2022,2023]
    },
    "Vespa": {
      "GTS_300":   [2021,2022,2023],
      "GTS_125":   [2021,2022,2023],
      "GTS_310":   [2024]
    },
    "Husqvarna": {
      "Svartpilen": [2021,2022,2023]
    },
    "Kymco": {
      "AK_550": [2021,2022,2023,2024]
    },
    "CFMoto": {
      "450MT": [2024]
    }
  };

  function toDisplay(key) {
    return key.replace(/_/g, ' ');
  }

  var data    = window.vault34FitmentData;
  var makeEl  = document.querySelector('[data-fitment-make]');
  var modelEl = document.querySelector('[data-fitment-model]');
  var yearEl  = document.querySelector('[data-fitment-year]');
  var submitEl= document.querySelector('[data-fitment-submit]');

  if (!makeEl) return;

  // Populate makes
  Object.keys(data).sort().forEach(function(make) {
    var opt = document.createElement('option');
    opt.value = make;
    opt.textContent = toDisplay(make);
    makeEl.appendChild(opt);
  });

  makeEl.addEventListener('change', function() {
    var make = makeEl.value;
    modelEl.innerHTML = '<option value="">Select Model</option>';
    yearEl.innerHTML  = '<option value="">Select Year</option>';
    modelEl.disabled  = true;
    yearEl.disabled   = true;

    if (make && data[make]) {
      Object.keys(data[make]).sort().forEach(function(model) {
        var opt = document.createElement('option');
        opt.value = model;
        opt.textContent = toDisplay(model);
        modelEl.appendChild(opt);
      });
      modelEl.disabled = false;
    }
  });

  modelEl.addEventListener('change', function() {
    var make  = makeEl.value;
    var model = modelEl.value;
    yearEl.innerHTML = '<option value="">Select Year</option>';
    yearEl.disabled  = true;

    if (make && model && data[make] && data[make][model]) {
      var years = data[make][model].slice().sort(function(a,b){ return b - a; });
      years.forEach(function(yr) {
        var opt = document.createElement('option');
        opt.value = yr;
        opt.textContent = yr;
        yearEl.appendChild(opt);
      });
      yearEl.disabled = false;
    }
  });

  submitEl && submitEl.addEventListener('click', function() {
    var make  = makeEl.value;
    var model = modelEl.value;
    var year  = yearEl.value;
    if (!make || !model || !year) return;

    // Save to recent bikes
    try {
      var saved = JSON.parse(localStorage.getItem('vault34_recent_bikes') || '[]');
      var entry = { make: make, model: model, year: year };
      saved = saved.filter(function(b) {
        return !(b.make === make && b.model === model && b.year === year);
      });
      saved.unshift(entry);
      localStorage.setItem('vault34_recent_bikes', JSON.stringify(saved.slice(0, 5)));
    } catch(e) {}

    // Navigate to filtered collection using Shopify tag URL format
    window.location.href = '/collections/all/MAKE_' + make + '+MODEL_' + model + '+YEAR_' + year;
  });

  // Recent bikes from localStorage
  var recent = [];
  try { recent = JSON.parse(localStorage.getItem('vault34_recent_bikes') || '[]'); } catch(e) {}

  if (recent.length) {
    var recentEl   = document.getElementById('fitment-recent');
    var recentList = document.getElementById('fitment-recent-list');
    if (recentEl && recentList) {
      recentEl.style.display = 'block';
      recentList.innerHTML = recent.slice(0, 4).map(function(bike) {
        var url = '/collections/all/MAKE_' + bike.make + '+MODEL_' + bike.model + '+YEAR_' + bike.year;
        return '<a href="' + url + '" class="filter-chip" style="font-size:var(--text-xs)">' +
          bike.year + ' ' + toDisplay(bike.make) + ' ' + toDisplay(bike.model) +
          '</a>';
      }).join('');
    }
  }
})();
</script>

{% schema %}
{
  "name": "Fitment Finder",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Find Parts for Your Bike"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Select your make, model and year to see exactly what fits."
    },
    {
      "type": "text",
      "id": "hint",
      "label": "Hint text",
      "default": "Compatible with 500+ bike models — updated weekly"
    },
    {
      "type": "select",
      "id": "bg_style",
      "label": "Background",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "elevated", "label": "Elevated" }
      ],
      "default": "elevated"
    }
  ],
  "presets": [
    {
      "name": "Fitment Finder"
    }
  ]
}
{% endschema %}
