{%- comment -%}
  PRODUCT PAGE — MAIN SECTION
  Two-column layout: sticky gallery left, product info right.
  Includes: gallery, specs, variants, ATC, sound module, reviews.
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: product.id
-%}

<section style="padding-top:var(--space-8);padding-bottom:var(--space-16);background:var(--bg-base)">
  <div class="container">

    <!-- Breadcrumb -->
    <nav class="product-info__breadcrumb" style="margin-bottom:var(--space-6)" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <svg width="12" height="12" fill="none" aria-hidden="true"><path d="M4 3l3 3-3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <svg width="12" height="12" fill="none" aria-hidden="true"><path d="M4 3l3 3-3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      {%- endif -%}
      <span style="color:var(--text-primary)">{{ product.title }}</span>
    </nav>

    <!-- Two-column layout -->
    <div class="product-layout">

      <!-- LEFT: Gallery -->
      <div class="product-gallery" data-product-gallery>

        <!-- Main image -->
        <div class="product-gallery__main">
          {%- if product.featured_image -%}
            <img
              class="product-gallery__main-img"
              src="{{ product.featured_image | image_url: width: 900 }}"
              srcset="
                {{ product.featured_image | image_url: width: 600 }} 600w,
                {{ product.featured_image | image_url: width: 900 }} 900w,
                {{ product.featured_image | image_url: width: 1200 }} 1200w
              "
              sizes="(max-width: 1024px) 100vw, 50vw"
              alt="{{ product.featured_image.alt | escape | default: product.title }}"
              width="900" height="900"
              loading="eager"
              fetchpriority="high"
              data-gallery-main
            >
          {%- else -%}
            <div style="width:100%;height:100%;background:var(--bg-surface);display:flex;align-items:center;justify-content:center">
              <svg width="64" height="64" fill="none" style="opacity:.15"><rect x="8" y="8" width="48" height="48" rx="8" stroke="currentColor" stroke-width="2"/><circle cx="24" cy="26" r="6" stroke="currentColor" stroke-width="2"/><path d="M8 44l12-12 10 10 8-8 14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
          {%- endif -%}

          <!-- Zoom hint -->
          <div style="position:absolute;bottom:var(--space-3);right:var(--space-3);background:rgba(0,0,0,.6);backdrop-filter:blur(8px);border-radius:var(--radius-md);padding:var(--space-1) var(--space-2);font-size:var(--text-xs);color:var(--text-muted);display:flex;align-items:center;gap:var(--space-1);pointer-events:none">
            <svg width="12" height="12" fill="none"><circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.3"/><path d="M9.5 9.5L12 12M7 5v2M5 7h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
            Click to zoom
          </div>
        </div>

        <!-- Thumbnails -->
        {%- if product.images.size > 1 -%}
          <div class="product-gallery__thumbs">
            {%- for image in product.images limit: 5 -%}
              <button
                class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
                data-gallery-thumb="{{ image | image_url: width: 900 }}"
                data-gallery-thumb-srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 900 }} 900w"
                data-alt="{{ image.alt | escape }}"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 120 }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  width="120" height="120"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Sound module -->
        {%- if product.metafields.vault34.audio_url != blank or product.tags contains 'has-sound' -%}
          <div class="product-sound-module" data-sound-player>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-4)">
              <div style="display:flex;align-items:center;gap:var(--space-3)">
                <div class="fitment-bar__label-icon">
                  <svg width="16" height="16" fill="none">
                    <path d="M6 3v10M10 1v14M2 7v2M14 7v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </div>
                <div>
                  <p style="font-size:var(--text-xs);font-weight:var(--font-semibold);letter-spacing:var(--tracking-wider);text-transform:uppercase;color:var(--purple-300)">Exhaust Sound</p>
                  <p style="font-size:var(--text-xs);color:var(--text-subtle)">Listen before you buy</p>
                </div>
              </div>
              <button
                class="btn btn-primary btn-sm"
                data-sound-play
                {%- if product.metafields.vault34.audio_url != blank -%}
                  data-sound-src="{{ product.metafields.vault34.audio_url }}"
                {%- endif -%}
                aria-label="Play exhaust audio"
              >
                <svg width="12" height="12" fill="none" data-icon-play><path d="M4 2l7 4-7 4V2z" fill="currentColor"/></svg>
                <svg width="12" height="12" fill="none" data-icon-pause style="display:none"><rect x="2" y="2" width="3.5" height="8" rx=".5" fill="currentColor"/><rect x="6.5" y="2" width="3.5" height="8" rx=".5" fill="currentColor"/></svg>
                Play Sound
              </button>
            </div>
            <div class="sound-waveform" aria-hidden="true">
              {%- for i in (1..24) -%}
                {%- assign h = i | modulo: 6 | plus: 2 -%}
                <div class="sound-waveform__bar" style="height:{{ h | times: 3 }}px;animation-delay:{{ forloop.index | times: 0.06 }}s"></div>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

      </div><!-- /gallery -->

      <!-- RIGHT: Product Info -->
      <div class="product-info" data-variant-form>

        <!-- Header -->
        <div class="product-info__header">
          {%- if product.vendor != blank -%}
            <a href="/collections/vendors?q={{ product.vendor | url_encode }}" class="label">{{ product.vendor }}</a>
          {%- endif -%}

          <h1 class="product-info__title" itemprop="name">{{ product.title }}</h1>

          <!-- Rating -->
          {%- assign rating = product.metafields.reviews.rating.value -%}
          {%- assign count  = product.metafields.reviews.rating_count -%}
          {%- if rating != blank -%}
            <div style="display:flex;align-items:center;gap:var(--space-3)">
              <div class="product-card__rating">
                <div class="stars" aria-label="{{ rating }} out of 5 stars">
                  {%- for i in (1..5) -%}
                    <span class="star" style="font-size:14px">{% if i <= rating %}★{% else %}☆{% endif %}</span>
                  {%- endfor -%}
                </div>
                {%- if count != blank -%}
                  <a href="#reviews" class="rating-count" style="color:var(--text-muted)">{{ count }} reviews</a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>

        <!-- Price block -->
        <div class="product-info__price-block">
          <span class="product-info__price-main" data-variant-price>
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="price-compare" data-variant-compare>{{ current_variant.compare_at_price | money }}</span>
            {%- assign discount = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
            <span class="price-badge">Save {{ discount }}%</span>
          {%- else -%}
            <span data-variant-compare style="display:none"></span>
          {%- endif -%}
        </div>

        <!-- Stock status -->
        <p data-variant-stock style="font-size:var(--text-sm);color:{{ current_variant.available ? 'var(--color-success)' : 'var(--text-subtle)' }}">
          {%- if current_variant.available -%}
            ● In Stock
            {%- if current_variant.inventory_quantity > 0 and current_variant.inventory_quantity < 5 -%}
              <span style="color:var(--color-warning)"> — Only {{ current_variant.inventory_quantity }} left</span>
            {%- endif -%}
          {%- else -%}
            ○ Out of Stock
          {%- endif -%}
        </p>

        <!-- Fitment match -->
        {%- assign saved_bike = 'vault34_bike' -%}
        {%- comment -%}Fitment match shown client-side via JS if bike is saved{%- endcomment -%}
        <div id="fitment-match-badge" style="display:none" class="fitment-match">
          <div class="fitment-match__icon" aria-hidden="true">
            <svg width="10" height="10" fill="none"><path d="M2 5l2.5 2.5L8 3" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <span>Fits your <span id="fitment-match-bike"></span></span>
        </div>

        <!-- Trust micro-signals — near ATC for maximum visibility -->
        <div style="display:flex;flex-wrap:wrap;gap:var(--space-3);padding:var(--space-3) 0">
          <div class="trust-item" style="gap:var(--space-2)">
            <svg width="14" height="14" fill="none"><path d="M2 7l3.5 3.5 6.5-6" stroke="var(--purple-300)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span style="font-size:var(--text-xs)">Fitment guaranteed</span>
          </div>
          <div class="trust-item" style="gap:var(--space-2)">
            <svg width="14" height="14" fill="none"><rect x="3" y="6" width="8" height="6" rx="1" stroke="var(--purple-300)" stroke-width="1.3"/><path d="M5 6V5a2 2 0 014 0v1" stroke="var(--purple-300)" stroke-width="1.3" stroke-linecap="round"/></svg>
            <span style="font-size:var(--text-xs)">Secure checkout</span>
          </div>
          <div class="trust-item" style="gap:var(--space-2)">
            <svg width="14" height="14" fill="none"><path d="M2 9h8V5H2v4zm8 0l3 2H2m9-2h2l2 2v2h-2M10 14a1.5 1.5 0 100-3 1.5 1.5 0 000 3zM5 14a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" stroke="var(--purple-300)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span style="font-size:var(--text-xs)">Worldwide shipping</span>
          </div>
          <div class="trust-item" style="gap:var(--space-2)">
            <svg width="14" height="14" fill="none"><path d="M4 8a4 4 0 008 0 4 4 0 00-8 0zM7 4V2M7 10v2" stroke="var(--purple-300)" stroke-width="1.3" stroke-linecap="round"/></svg>
            <span style="font-size:var(--text-xs)">30-day returns</span>
          </div>
        </div>

        <!-- Product form -->
        {%- form 'product', product, id: product_form_id, data-atc-form: '' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          <!-- Variant selectors -->
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="variant-group" data-option-group>
                <div class="variant-group__label">
                  {{ option.name }}
                  <span class="variant-group__selected" id="option-selected-{{ forloop.index }}">{{ option.selected_value }}</span>
                </div>
                <div class="variant-options">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="variant-option{% if option.selected_value == value %} is-selected{% endif %}"
                      data-variant-option
                    >
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <!-- Variants JSON for JS -->
          <script type="application/json" data-variants-json>
            {{ product.variants | json }}
          </script>

          <!-- Quantity + ATC -->
          <div class="atc-section" data-sticky-atc-trigger>
            <div class="atc-main">
              <!-- Quantity -->
              <div class="quantity-input" aria-label="Quantity">
                <button type="button" class="quantity-btn" data-qty-dec aria-label="Decrease">
                  <svg width="12" height="12" fill="none"><path d="M2 6h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
                <input
                  type="number"
                  class="quantity-field"
                  name="quantity"
                  value="1"
                  min="1"
                  aria-label="Quantity"
                >
                <button type="button" class="quantity-btn" data-qty-inc aria-label="Increase">
                  <svg width="12" height="12" fill="none"><path d="M6 2v8M2 6h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
              </div>

              <!-- ATC button -->
              <button
                type="submit"
                class="btn btn-primary btn-full btn-xl"
                data-atc-btn
                data-default-text="{{ current_variant.available | ternary: 'Add to Cart', 'Out of Stock' }}"
                {%- unless current_variant.available -%}disabled{%- endunless -%}
              >
                {%- if current_variant.available -%}
                  <svg width="16" height="16" fill="none" aria-hidden="true">
                    <path d="M3 3h2.5l1.8 9H14M6.5 14.5a1.5 1.5 0 103 0 1.5 1.5 0 00-3 0zm5 0a1.5 1.5 0 103 0 1.5 1.5 0 00-3 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Add to Cart
                {%- else -%}
                  Out of Stock
                {%- endif -%}
              </button>
            </div>

            <!-- Buy it now -->
            {%- if section.settings.show_dynamic_checkout -%}
              {{ form | payment_button }}
            {%- endif -%}
          </div>

        {%- endform -%}

        <!-- Short description -->
        {%- if product.description != blank -%}
          <div style="font-size:var(--text-base);color:var(--text-muted);line-height:var(--leading-relaxed)">
            {{ product.description | strip_html | truncatewords: 50 }}
          </div>
        {%- endif -%}

        <!-- Key specs preview -->
        {%- if product.metafields.specs != blank -%}
          <div class="tech-specs">
            <div class="tech-specs__header">
              <div class="tech-specs__title">
                <div class="tech-specs__icon" aria-hidden="true">
                  <svg width="12" height="12" fill="none"><rect x="2" y="2" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.3"/><path d="M5 5h2M5 7h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                </div>
                Key Specs
              </div>
              <button class="btn btn-ghost btn-sm" data-toggle-specs aria-expanded="false">Show all</button>
            </div>
            {%- render 'product-specs', product: product -%}
          </div>
        {%- endif -%}

      </div><!-- /product-info -->
    </div><!-- /product-layout -->

    <!-- Full description + specs tabs -->
    <div style="margin-top:var(--space-16);border-top:1px solid var(--border-subtle);padding-top:var(--space-12)">
      {%- render 'product-tabs', product: product -%}
    </div>

    <!-- Reviews section -->
    <div id="reviews" style="margin-top:var(--space-12)">
      {%- render 'review-module', product: product -%}
    </div>

    <!-- Related products -->
    {%- render 'related-products', product: product, collection: collection -%}

  </div>
</section>

<!-- Sticky ATC data -->
<script>
(function() {
  var bike = null;
  try { bike = JSON.parse(localStorage.getItem('vault34_recent_bikes') || '[]')[0]; } catch {}
  if (!bike) return;

  var badge  = document.getElementById('fitment-match-badge');
  var bikeEl = document.getElementById('fitment-match-bike');
  var tag    = (bike.make + '_' + bike.model + '_' + bike.year).toLowerCase().replace(/\s+/g, '_');

  var productTags = {{ product.tags | json }};
  if (productTags.some(function(t) { return t.toLowerCase() === tag || t.toLowerCase().includes(bike.make.toLowerCase()); })) {
    if (badge) badge.style.display = 'flex';
    if (bikeEl) bikeEl.textContent = bike.year + ' ' + bike.make + ' ' + bike.model;
  }
})();
</script>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout buttons",
      "default": true
    }
  ]
}
{% endschema %}
