{%- comment -%}
  MEGA MENU SNIPPET
  Usage: render 'mega-menu', link: link
  Renders a dropdown panel with categorized sub-links and optional featured image.
{%- endcomment -%}

<div class="mega-menu" role="region" aria-label="{{ link.title }} menu">
  <div class="mega-menu__grid">

    {%- comment -%} Auto-group sub-links into columns of 6 {%- endcomment -%}
    {%- assign col_links = link.links -%}
    {%- assign total_links = col_links.size -%}
    {%- assign links_per_col = 5 -%}
    {%- assign num_cols = total_links | divided_by: links_per_col | ceil -%}
    {%- assign num_cols = num_cols | at_most: 2 -%}

    {%- if num_cols == 1 -%}
      <div class="mega-menu__col" style="grid-column:span 2">
        {%- for sub in col_links -%}
          <a href="{{ sub.url }}" class="mega-menu__item">
            <div class="mega-menu__item-icon" aria-hidden="true">
              <svg width="14" height="14" fill="none">
                <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span>{{ sub.title }}</span>
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- assign half = total_links | divided_by: 2 | ceil -%}
      <div class="mega-menu__col">
        {%- for sub in col_links limit: half -%}
          <a href="{{ sub.url }}" class="mega-menu__item">
            <div class="mega-menu__item-icon" aria-hidden="true">
              <svg width="14" height="14" fill="none">
                <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span>{{ sub.title }}</span>
          </a>
        {%- endfor -%}
      </div>
      <div class="mega-menu__col">
        {%- for sub in col_links offset: half -%}
          <a href="{{ sub.url }}" class="mega-menu__item">
            <div class="mega-menu__item-icon" aria-hidden="true">
              <svg width="14" height="14" fill="none">
                <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <span>{{ sub.title }}</span>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <!-- Featured collection card -->
    <div class="mega-menu__featured-col">
      <p class="mega-menu__section-title">Featured</p>
      <a href="{{ link.url }}" class="mega-menu__featured">
        {%- assign featured_collection = link.object -%}
        {%- if featured_collection.image -%}
          <img
            src="{{ featured_collection.image | image_url: width: 320 }}"
            alt="{{ featured_collection.title }}"
            width="320" height="180"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;filter:saturate(0.6)"
          >
        {%- else -%}
          <div style="width:100%;height:100%;background:var(--bg-surface);display:flex;align-items:center;justify-content:center">
            <svg width="32" height="32" fill="none" style="opacity:.2">
              <rect x="4" y="4" width="24" height="24" rx="4" stroke="currentColor" stroke-width="2"/>
              <circle cx="12" cy="13" r="3" stroke="currentColor" stroke-width="2"/>
              <path d="M4 22l6-6 5 5 4-4 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
        {%- endif -%}
        <span class="mega-menu__featured-label">{{ link.title }}</span>
      </a>

      <!-- View all -->
      <a href="{{ link.url }}" class="btn btn-secondary btn-sm" style="width:100%;margin-top:var(--space-3);justify-content:center">
        View All {{ link.title }}
        <svg width="12" height="12" fill="none" style="flex-shrink:0">
          <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>

  <!-- Bottom accent bar -->
  <div style="height:2px;background:linear-gradient(90deg,transparent,var(--purple-primary),transparent);margin-top:var(--space-5);margin-inline:-var(--space-6)"></div>
</div>

<style>
.mega-menu__grid {
  display: grid;
  grid-template-columns: 1fr 1fr 200px;
  gap: var(--space-6);
}
.mega-menu__col {
  display: flex;
  flex-direction: column;
}
.mega-menu__col > .mega-menu__section-title {
  margin-bottom: var(--space-3);
}
</style>
