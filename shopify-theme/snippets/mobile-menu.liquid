{%- comment -%}
  MOBILE MENU SNIPPET
  Full-panel slide-in drawer with accordion sub-menus.
{%- endcomment -%}

<div id="mobile-menu" class="mobile-menu" role="dialog" aria-label="Main menu" aria-modal="true">
  <div class="mobile-menu__backdrop" aria-hidden="true"></div>

  <div class="mobile-menu__panel">

    <!-- Header -->
    <div class="mobile-menu__header">
      <a href="{{ routes.root_url }}" class="site-header__logo" style="font-size:var(--text-lg)">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: height: 32 }}" alt="{{ shop.name }}" height="32" loading="lazy">
        {%- else -%}
          <div class="site-header__logo-mark" style="width:28px;height:28px" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
              <path d="M9 2L15.5 6V12L9 16L2.5 12V6L9 2Z" fill="white"/>
            </svg>
          </div>
          <span>{{ shop.name | upcase }}</span>
        {%- endif -%}
      </a>

      <button
        class="header-action-btn"
        data-mobile-menu-close
        aria-label="Close menu"
      >
        <svg width="18" height="18" fill="none" aria-hidden="true">
          <path d="M2 2l14 14M16 2L2 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div><!-- /header -->

    <!-- Nav -->
    <nav class="mobile-menu__nav" aria-label="Mobile navigation">

      <!-- Fitment quick-find -->
      <div style="margin-bottom:var(--space-4);padding:var(--space-3) var(--space-4);background:var(--purple-fill);border:1px solid var(--border-purple);border-radius:var(--radius-lg)">
        <p style="font-size:var(--text-xs);font-weight:var(--font-semibold);letter-spacing:var(--tracking-wider);text-transform:uppercase;color:var(--purple-300);margin-bottom:var(--space-2)">Find Parts For Your Bike</p>
        <a href="/pages/fitment-finder" class="btn btn-secondary btn-sm" style="width:100%;justify-content:center">
          <svg width="14" height="14" fill="none">
            <circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.4"/>
            <path d="M9.5 9.5L13 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          Fitment Finder
        </a>
      </div>

      {%- for link in linklists[settings.mobile_menu | default: 'main-menu'].links -%}
        {%- if link.links != blank -%}
          <div class="mobile-nav-item">
            <button
              class="mobile-nav-link"
              data-has-sub
              aria-expanded="false"
              style="width:100%;text-align:left;background:transparent;border:none;cursor:pointer"
            >
              {{ link.title }}
              <svg width="14" height="14" fill="none" style="flex-shrink:0;transition:transform .2s">
                <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="mobile-nav-submenu">
              {%- for sub in link.links -%}
                <a href="{{ sub.url }}" class="mobile-nav-sublink">{{ sub.title }}</a>
              {%- endfor -%}
              <a href="{{ link.url }}" class="mobile-nav-sublink" style="color:var(--purple-300)">View all {{ link.title }}</a>
            </div>
          </div>
        {%- else -%}
          <div class="mobile-nav-item">
            <a href="{{ link.url }}" class="mobile-nav-link{% if link.active %} is-active{% endif %}">
              {{ link.title }}
            </a>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </nav><!-- /nav -->

    <!-- Footer -->
    <div class="mobile-menu__footer">
      <div style="display:flex;gap:var(--space-3);margin-bottom:var(--space-4)">
        {%- if settings.show_account -%}
          <a href="{{ customer ? routes.account_url : routes.account_login_url }}"
             class="btn btn-secondary btn-sm" style="flex:1;justify-content:center">
            <svg width="14" height="14" fill="none">
              <circle cx="7" cy="5" r="2.5" stroke="currentColor" stroke-width="1.4"/>
              <path d="M2 13c0-2.5 2.2-4.5 5-4.5s5 2 5 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
            {{ customer ? 'Account' : 'Sign In' }}
          </a>
        {%- endif -%}
        <button class="btn btn-ghost btn-sm" data-search-open style="flex:1;justify-content:center">
          <svg width="14" height="14" fill="none">
            <circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.4"/>
            <path d="M9.5 9.5L12.5 12.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          Search
        </button>
      </div>

      <!-- Social -->
      {%- if settings.social_instagram != blank or settings.social_facebook != blank or settings.social_youtube != blank -%}
        <div style="display:flex;gap:var(--space-2);padding-top:var(--space-3);border-top:1px solid var(--border-subtle)">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" class="social-link" target="_blank" rel="noopener" aria-label="Instagram">IG</a>
          {%- endif -%}
          {%- if settings.social_youtube != blank -%}
            <a href="{{ settings.social_youtube }}" class="social-link" target="_blank" rel="noopener" aria-label="YouTube">YT</a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" class="social-link" target="_blank" rel="noopener" aria-label="Facebook">FB</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div><!-- /footer -->

  </div><!-- /panel -->
</div><!-- /mobile-menu -->

<style>
/* Rotate chevron on open */
.mobile-nav-link.is-open svg { transform: rotate(180deg); }
</style>

<script>
/* Accordion logic inline for reliability */
document.querySelectorAll('.mobile-nav-link[data-has-sub]').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var item = btn.closest('.mobile-nav-item');
    var sub  = item && item.querySelector('.mobile-nav-submenu');
    if (!sub) return;
    var isOpen = sub.classList.contains('is-open');
    document.querySelectorAll('.mobile-nav-submenu.is-open').forEach(function(s) {
      s.classList.remove('is-open');
      s.closest('.mobile-nav-item').querySelector('.mobile-nav-link').classList.remove('is-open');
    });
    if (!isOpen) {
      sub.classList.add('is-open');
      btn.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
    } else {
      btn.setAttribute('aria-expanded', 'false');
    }
  });
});
</script>
