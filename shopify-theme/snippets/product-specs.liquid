{%- comment -%}
  PRODUCT SPECS SNIPPET
  Usage: render 'product-specs', product: product
  Reads from product.metafields.specs or falls back to description parsing.
{%- endcomment -%}

{%- liquid
  assign specs = product.metafields.specs
  assign show_all = false
-%}

{%- if specs != blank -%}
  <div class="tech-specs__table" id="specs-table">
    {%- for spec in specs -%}
      <div class="tech-specs__row">
        <div class="tech-specs__key">{{ spec.key }}</div>
        <div class="tech-specs__value">{{ spec.value }}</div>
      </div>
    {%- endfor -%}
  </div>
{%- else -%}
  {%- comment -%}
    Fallback: parse description for spec-like lines.
    Looks for lines matching "Label: Value" pattern.
    In production, replace with proper metafield data.
  {%- endcomment -%}
  {%- assign desc_lines = product.description | strip_html | newline_to_br | split: '<br />' -%}
  {%- assign spec_lines = '' -%}
  {%- for line in desc_lines -%}
    {%- if line contains ':' -%}
      {%- assign spec_lines = spec_lines | append: line | append: '|||' -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if spec_lines != blank -%}
    <div class="tech-specs__table" id="specs-table">
      {%- assign specs_arr = spec_lines | split: '|||' -%}
      {%- for spec_line in specs_arr limit: 10 -%}
        {%- if spec_line != blank -%}
          {%- assign parts = spec_line | split: ':' -%}
          {%- if parts.size >= 2 -%}
            <div class="tech-specs__row">
              <div class="tech-specs__key">{{ parts[0] | strip }}</div>
              <div class="tech-specs__value">{{ parts[1] | strip }}</div>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
{%- endif -%}

<style>
#specs-table .tech-specs__row:nth-child(n+7) { display: none; }
#specs-table.show-all .tech-specs__row { display: grid !important; }
</style>

<script>
var toggleBtn = document.querySelector('[data-toggle-specs]');
if (toggleBtn) {
  toggleBtn.addEventListener('click', function() {
    var table = document.getElementById('specs-table');
    if (!table) return;
    var expanded = table.classList.toggle('show-all');
    toggleBtn.textContent = expanded ? 'Show less' : 'Show all';
    toggleBtn.setAttribute('aria-expanded', expanded);
  });
}
</script>
