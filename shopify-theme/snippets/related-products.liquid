{%- comment -%}
  RELATED PRODUCTS
  Shows up to 4 products from the same collection, excluding the current product.
  Usage: render 'related-products', product: product, collection: collection
{%- endcomment -%}

{%- liquid
  assign source = collection | default: collections.all
  assign related_limit = 4
  assign shown = 0
-%}

{%- capture related_html -%}
  {%- for p in source.products -%}
    {%- unless p.id == product.id -%}
      {%- if shown < related_limit -%}
        {%- render 'product-card', product: p, index: forloop.index -%}
        {%- assign shown = shown | plus: 1 -%}
      {%- endif -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endcapture -%}

{%- if shown > 0 -%}
<div class="reveal" style="margin-top:var(--space-16);border-top:1px solid var(--border-subtle);padding-top:var(--space-12)">
  <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:var(--space-8);gap:var(--space-4);flex-wrap:wrap">
    <div>
      <p class="label" style="margin-bottom:var(--space-3)">You May Also Like</p>
      <h2 class="h3">Related Products</h2>
    </div>
    <a href="{{ source.url | default: '/collections/all' }}" class="btn btn-secondary" style="flex-shrink:0">
      View All
      <svg width="14" height="14" fill="none" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
  <div class="grid" style="grid-template-columns:repeat({{ shown }},1fr)">
    {{ related_html }}
  </div>
</div>
{%- endif -%}
