{%- comment -%}
  REVIEW MODULE SNIPPET
  Usage: render 'review-module', product: product
  Renders product reviews summary + cards grid.
  In production: wire to Shopify Product Reviews app or Okendo/Yotpo.
{%- endcomment -%}

{%- liquid
  assign rating_value = product.metafields.reviews.rating.value
  assign review_count = product.metafields.reviews.rating_count | default: 0
-%}

{%- if review_count > 0 or product.metafields.reviews != blank -%}
  <div class="reveal">

    <!-- Summary header -->
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:var(--space-8);flex-wrap:wrap;gap:var(--space-6)">
      <div>
        <p class="label" style="margin-bottom:var(--space-3)">Customer Reviews</p>
        <div style="display:flex;align-items:center;gap:var(--space-4)">
          <span style="font-size:var(--text-6xl);font-weight:var(--font-black);letter-spacing:var(--tracking-tightest);color:var(--text-primary)">{{ rating_value }}</span>
          <div>
            <div class="stars" aria-label="{{ rating_value }} out of 5">
              {%- for i in (1..5) -%}
                <span class="star" style="font-size:20px">{% if i <= rating_value %}★{% else %}☆{% endif %}</span>
              {%- endfor -%}
            </div>
            <p style="font-size:var(--text-sm);color:var(--text-subtle);margin-top:var(--space-1)">
              Based on {{ review_count }} reviews
            </p>
          </div>
        </div>
      </div>

      <!-- Write review CTA -->
      <a href="#write-review" class="btn btn-secondary">
        Write a Review
        <svg width="14" height="14" fill="none">
          <path d="M11 2l1 1-7 7H4v-1l7-7zM9 4l1 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Review cards -->
    {%- if product.metafields.reviews.reviews != blank -%}
      <div class="grid sm:grid-cols-2 lg:grid-cols-3">
        {%- for review in product.metafields.reviews.reviews limit: 6 -%}
          <article class="review-card">
            <div class="review-card__header">
              <div class="review-card__author">
                <div class="review-card__avatar" aria-hidden="true">
                  {{ review.author | slice: 0 | upcase }}
                </div>
                <div>
                  <div class="review-card__name">{{ review.author }}</div>
                  {%- if review.bike != blank -%}
                    <div class="review-card__bike">{{ review.bike }}</div>
                  {%- endif -%}
                </div>
              </div>
              <div class="stars" aria-label="{{ review.rating }} stars">
                {%- for i in (1..5) -%}
                  <span class="star">{% if i <= review.rating %}★{% else %}☆{% endif %}</span>
                {%- endfor -%}
              </div>
            </div>
            {%- if review.title != blank -%}
              <p style="font-size:var(--text-sm);font-weight:var(--font-semibold);color:var(--text-primary);margin-bottom:var(--space-2)">{{ review.title }}</p>
            {%- endif -%}
            <p class="review-card__body">{{ review.body }}</p>
            <div class="review-card__footer">
              <div class="review-verified">
                <svg width="10" height="10" fill="none"><path d="M2 5l2.5 2.5L8 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Verified Purchase
              </div>
              {%- if review.date != blank -%}
                <span style="font-size:var(--text-xs);color:var(--text-subtle)">{{ review.date }}</span>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <!-- No reviews yet -->
      <div style="text-align:center;padding:var(--space-12) var(--space-4);color:var(--text-subtle)">
        <svg width="40" height="40" fill="none" style="margin:0 auto var(--space-4);display:block;opacity:.3">
          <path d="M20 5l3.5 8h8.5l-7 5.5 2.5 8.5L20 22l-7.5 5 2.5-8.5L8 13h8.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
        <p style="font-size:var(--text-sm);margin-bottom:var(--space-2)">No reviews yet — be the first!</p>
        <p style="font-size:var(--text-xs)">Share your experience and help other riders.</p>
      </div>
    {%- endif -%}

    <!-- Review app integration point -->
    <div id="write-review" style="margin-top:var(--space-8)">
      {%- comment -%} Wire in your review app here, e.g. Shopify Reviews, Okendo, Judge.me {%- endcomment -%}
      {{ product.metafields.reviews.write_review_form }}
    </div>

  </div>
{%- endif -%}
